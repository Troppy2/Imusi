# =============================================================================
# IMUSI Backend - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
# Local development (SQLite - default):
# DATABASE_URL=sqlite:///./data/imusi.db
#
# Production (PostgreSQL on Neon):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/imusi?sslmode=require

DATABASE_URL=sqlite:///./data/imusi.db

# --- Environment ---
ENVIRONMENT=development

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-32-plus-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-32-plus-char-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=imusi-backend
JWT_AUDIENCE=imusi-mobile
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_PATHS=["/api/v1/auth/login","/api/v1/auth/google","/api/v1/auth/signup"]

# --- Song Import ---
AUTO_IMPORT_GLOBAL_SONGS_ON_STARTUP=true
GLOBAL_SONGS_DIR=./songs
GLOBAL_SONGS_WATCH_ENABLED=true

# --- Spotify OAuth ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Spotify-to-Local Download Pipeline ---
# Directory where downloaded music files will be stored
MUSIC_DOWNLOAD_DIR=./music
# Audio format: mp3, m4a, aac
DOWNLOAD_AUDIO_FORMAT=mp3
# Audio quality in kbps
DOWNLOAD_AUDIO_QUALITY=192

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# --- Logging ---
LOG_LEVEL=INFO
