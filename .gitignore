# Root .gitignore for Imusi project

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
env/
*.env
*.egg-info/
dist/
build/

# SQLite DB
backend/data/*.db

# Node/Expo
node_modules/
pnpm-lock.yaml
yarn.lock
package-lock.json
/mobile/node_modules/
/mobile/dist/
/mobile/.expo/
/mobile/*.tsbuildinfo

# misc
.DS_Store
*.log

# keep config files
!.env.example
